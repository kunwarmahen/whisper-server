# Whisper model to load (downloaded on first start, cached in ./models/)
#
# Available sizes (Systran/faster-whisper-*):
#   tiny      ~150 MB   fastest, lower accuracy
#   base      ~290 MB
#   small     ~500 MB
#   medium    ~1.5 GB   good balance (default)
#   large-v3  ~3.1 GB   most accurate, needs ~4 GB RAM
#
WHISPER_MODEL=Systran/faster-whisper-medium
